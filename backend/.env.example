# ============================================
# Sprintly Backend Environment Configuration
# ============================================

# Environment mode (use 'development' for local dev / 'production' for deploy)
NODE_ENV=development
PORT=5000

# Database (MongoDB)
# Replace with your MongoDB connection string (local or Atlas)
MONGO_URI=your_mongoDb_url

# JWT Authentication
# IMPORTANT: Change JWT_SECRET to a strong, unique random secret in production!
JWT_SECRET=your_jwt_secret
JWT_EXPIRE=30d
JWT_COOKIE_EXPIRE=30

# Frontend URL (used for CORS)
# For local dev, this matches your React dev server default; adjust for production as needed
FRONTEND_URL=http://localhost:3000



SMTP_HOST=you@smtp_host.com
SMTP_PORT=587
SMTP_EMAIL=your_smtp_email
SMTP_PASSWORD=your_smtp_password
FROM_NAME=Sprintly

# Cloudinary (Optional – for file/image uploads, e.g., profile avatars / attachments)
# Sign up at https://cloudinary.com and fill in your credentials
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret


# Rate Limiting (optional safety controls)
RATE_LIMIT_WINDOW=900000  # 15 minutes in milliseconds (15 * 60 * 1000)
RATE_LIMIT_MAX_REQUESTS=100  # Max requests per window per IP

